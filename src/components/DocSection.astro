---
/**
 * DocSection — renders its slot only when `id` matches `current`.
 *
 * Used in _includes MDX files to split content into named sections
 * while keeping the content as markdown (not JSX/HTML).
 *
 * Usage:
 *   <DocSection id="prerequisites" current={props.section}>
 *
 *   Markdown content here.
 *
 *   </DocSection>
 */
interface Props {
  id: string;
  current: string;
}

const { id, current } = Astro.props;
---

{id === current && <slot />}
