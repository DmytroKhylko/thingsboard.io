---
/**
 * Renders an inline <code> element with product-aware hostname substitution.
 * Use the same placeholders as HostCode ({COAP_HOST_LABEL}, {HTTP_URL_PREFIX}, etc.)
 * but renders inline code instead of a code block.
 */
import { getHostConfig } from '~/data/hosts';
import type { Products } from '~/models/site.models';

interface Props {
	product: Products;
	code: string;
}

const { product, code } = Astro.props;
const hosts = getHostConfig(product);

const replacements: Record<string, string> = hosts.isSelfHosted
	? {
			'{COAP_HOST_LABEL}': 'THINGSBOARD_HOST',
			'{HTTP_HOST_LABEL}': 'THINGSBOARD_HOST',
			'{LWM2M_HOST_LABEL}': 'THINGSBOARD_HOST',
		}
	: {
			'{COAP_HOST_LABEL}': hosts.coapHostName,
			'{HTTP_HOST_LABEL}': hosts.hostName,
			'{LWM2M_HOST_LABEL}': hosts.lwm2mHostName,
		};

let resolved = code;
for (const [placeholder, value] of Object.entries(replacements)) {
	resolved = resolved.replaceAll(placeholder, value);
}
---

<code>{resolved}</code>
