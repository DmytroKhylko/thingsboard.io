---
import type { IotHubNodeInfo } from '@models/iot-hub';

// Rule-chain node chips. Ports the platform `.dlg-nodes`
// row from
// /data/git/thingsboard/ui-ngx/src/app/modules/home/components/iot-hub/iot-hub-item-detail-dialog.component.html
// and the `.dlg-node-chip` styling from the sibling .scss. Each chip uses
// `node.name` as label and a `--{type}` modifier class for the colored
// background + border. Only rendered for RULE_CHAIN listings (see [slug].astro).

interface Props {
	nodes: IotHubNodeInfo[];
}

const { nodes } = Astro.props;

// Lowercase the type for class names (`FILTER` → `filter`), defaulting to
// `unknown` so a new backend value renders neutrally instead of unstyled.
const KNOWN_TYPES = new Set([
	'enrichment',
	'filter',
	'transformation',
	'action',
	'analytics',
	'external',
	'flow',
	'unknown',
]);
const classFor = (type: string) => {
	const t = type?.toLowerCase?.() ?? '';
	return KNOWN_TYPES.has(t) ? t : 'unknown';
};
---

{
	nodes.length > 0 && (
		<section class="iot-hub-rule-nodes" aria-label="Rule chain nodes">
			<ul class="iot-hub-rule-nodes__list" role="list">
				{nodes.map((node) => (
					<li
						class:list={[
							'iot-hub-rule-nodes__chip',
							`iot-hub-rule-nodes__chip--${classFor(node.type)}`,
						]}
						title={node.type}
					>
						{node.name}
					</li>
				))}
			</ul>
		</section>
	)
}

<style lang="scss">
	@use '~/styles/_variables.scss' as *;

	.iot-hub-rule-nodes {
		padding: 16px 16px;
		border-bottom: 1px solid var(--iot-hub-hairline);

		@include media-down(sm) {
			padding: 16px 12px;
		}
	}

	.iot-hub-rule-nodes__list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
	}

	// Pill chip — ported 1:1 from .dlg-node-chip
	// (iot-hub-item-detail-dialog.component.scss): 32px tall, pill radius,
	// 1px border at full color, background at 16% alpha. Body text reads
	// at rgba(0,0,0,0.76) on both themes (the saturated tinted backgrounds
	// keep the chip surface lighter than the page background even in dark
	// mode, so dark text stays legible).
	.iot-hub-rule-nodes__chip {
		display: inline-flex;
		align-items: center;
		height: 32px;
		padding: 6px 12px;
		border-radius: 16px;
		font-size: 14px;
		font-weight: $font-weight-medium;
		line-height: 20px;
		letter-spacing: 0.2px;
		white-space: nowrap;
		border: 1px solid;
		color: rgba(0, 0, 0, 0.76);

		&--filter {
			background: rgba(241, 232, 97, 0.16);
			border-color: rgb(241, 232, 97);
		}

		&--enrichment {
			background: rgba(205, 241, 78, 0.16);
			border-color: rgb(205, 241, 78);
		}

		&--transformation {
			background: rgba(121, 206, 241, 0.16);
			border-color: rgb(121, 206, 241);
		}

		&--action {
			background: rgba(241, 146, 143, 0.16);
			border-color: rgb(241, 146, 143);
		}

		&--analytics {
			background: rgba(49, 210, 204, 0.16);
			border-color: rgb(49, 210, 204);
		}

		&--external {
			background: rgba(251, 199, 102, 0.16);
			border-color: rgb(251, 199, 102);
		}

		&--flow {
			background: rgba(214, 196, 241, 0.16);
			border-color: rgb(214, 196, 241);
		}

		&--unknown {
			background: rgba(0, 0, 0, 0.04);
			border-color: rgba(0, 0, 0, 0.12);
		}
	}
</style>
