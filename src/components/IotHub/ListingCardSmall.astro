---
import type { CollectionEntry } from 'astro:content';

interface Props {
	entry: CollectionEntry<'iotHubListings'>;
	categorySlug: string;
}

const { entry, categorySlug } = Astro.props;
const { name, color, creatorDisplayName, creatorVerified, installCount, itemType } = entry.data;
const href = `/iot-hub/${categorySlug}/${entry.data.slug}/`;
const author = creatorDisplayName ?? 'ThingsBoard';

// Per-category fallback color when listing color is null.
const fallbackByType: Record<string, string> = {
	CALCULATED_FIELD: '#21b91b',
	ALARM_RULE: '#f59e0b',
	RULE_CHAIN: '#7a4dc3',
};
const tile = color ?? fallbackByType[itemType] ?? '#4c63cc';

// Per-category icon glyph (rendered on the colored tile).
const glyphByType: Record<string, string> = {
	CALCULATED_FIELD: 'fx',
	ALARM_RULE: '!',
	RULE_CHAIN: '↳',
};
const glyph = glyphByType[itemType] ?? '·';
---

<a class="iot-hub-card-sm" href={href}>
	<div class="iot-hub-card-sm__icon" style={`background-color:${tile};`} aria-hidden="true">
		<span class="iot-hub-card-sm__glyph">{glyph}</span>
	</div>
	<div class="iot-hub-card-sm__body">
		<h3 class="iot-hub-card-sm__title">{name}</h3>
		<div class="iot-hub-card-sm__meta">
			<div class="iot-hub-card-sm__author">
				{
					creatorVerified ? (
						<svg
							class="iot-hub-card-sm__author-icon"
							width="16"
							height="16"
							viewBox="0 0 16 16"
							fill="none"
							aria-hidden="true"
						>
							<path
								d="m8 1.333 2.04 1.5 2.527-.234.234 2.527 1.5 2.04-1.5 2.041-.234 2.527-2.527.234L8 13.467l-2.04-1.5-2.527-.234-.234-2.527-1.5-2.041 1.5-2.04.234-2.527 2.527.234L8 1.333Z"
								fill="var(--color-primary)"
							/>
							<path
								d="m5.667 8 1.666 1.667L10.667 6.333"
								stroke="#fff"
								stroke-width="1.4"
								stroke-linecap="round"
								stroke-linejoin="round"
							/>
						</svg>
					) : (
						<svg
							class="iot-hub-card-sm__author-icon"
							width="16"
							height="16"
							viewBox="0 0 16 16"
							fill="none"
							aria-hidden="true"
						>
							<path
								d="M8 8.667a2.667 2.667 0 1 0 0-5.334 2.667 2.667 0 0 0 0 5.334ZM3.333 13.333a4.667 4.667 0 0 1 9.334 0"
								stroke="currentColor"
								stroke-width="1.3"
								stroke-linecap="round"
								stroke-linejoin="round"
							/>
						</svg>
					)
				}
				<span>{author}</span>
			</div>
			<span class="iot-hub-card-sm__dot" aria-hidden="true"></span>
			<div class="iot-hub-card-sm__installs" title={`${installCount} installs`}>
				<svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
					<path
						d="M8 2v8.667M4.667 7.333 8 10.667l3.333-3.334M2.667 13.333h10.666"
						stroke="currentColor"
						stroke-width="1.3"
						stroke-linecap="round"
						stroke-linejoin="round"></path>
				</svg>
				<span>{installCount}</span>
			</div>
		</div>
	</div>
	<span class="iot-hub-card-sm__cta">Install</span>
</a>

<style lang="scss">
	@use '~/styles/_variables.scss' as *;

	.iot-hub-card-sm {
		display: flex;
		align-items: stretch;
		gap: 1rem;
		padding: 1rem;
		background: var(--color-bg-surface);
		border: 1px solid var(--color-border);
		border-radius: 8px;
		text-decoration: none;
		color: inherit;
		min-height: 104px;
		transition: transform $transition-fast, box-shadow $transition-fast, border-color $transition-fast;

		&:hover {
			transform: translateY(-1px);
			box-shadow: 0 6px 16px rgba(0, 0, 0, 0.06);
			border-color: var(--color-border-light);
			text-decoration: none;
		}

		[data-theme='dark'] &:hover {
			box-shadow: 0 8px 20px rgba(0, 0, 0, 0.25);
		}
	}

	.iot-hub-card-sm__icon {
		flex-shrink: 0;
		width: 72px;
		height: 72px;
		border-radius: 8px;
		display: flex;
		align-items: center;
		justify-content: center;
		color: #fff;
	}

	.iot-hub-card-sm__glyph {
		font-size: 28px;
		font-weight: $font-weight-bold;
		line-height: 1;
	}

	.iot-hub-card-sm__body {
		flex: 1;
		min-width: 0;
		display: flex;
		flex-direction: column;
		justify-content: center;
		gap: 0.25rem;
	}

	.iot-hub-card-sm__title {
		font-size: 16px;
		font-weight: $font-weight-semibold;
		line-height: 24px;
		margin: 0;
		color: var(--color-text);
		overflow: hidden;
		text-overflow: ellipsis;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
	}

	.iot-hub-card-sm__meta {
		display: flex;
		align-items: center;
		gap: 6px;
		font-size: 12px;
		line-height: 16px;
		color: var(--color-text-muted);
	}

	.iot-hub-card-sm__author {
		display: inline-flex;
		align-items: center;
		gap: 4px;
		min-width: 0;
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
	}

	.iot-hub-card-sm__author-icon {
		flex-shrink: 0;
		color: var(--color-text-muted);
	}

	.iot-hub-card-sm__dot {
		flex-shrink: 0;
		width: 3px;
		height: 3px;
		border-radius: 50%;
		background: var(--color-border);
	}

	.iot-hub-card-sm__installs {
		display: inline-flex;
		align-items: center;
		gap: 2px;
		flex-shrink: 0;
	}

	.iot-hub-card-sm__cta {
		align-self: center;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 6px 14px;
		font-size: 14px;
		font-weight: $font-weight-semibold;
		line-height: 24px;
		border: 1px solid var(--color-border);
		border-radius: 4px;
		color: var(--color-primary);

		.iot-hub-card-sm:hover & {
			border-color: var(--color-primary);
		}
	}
</style>
