---
import Navigation from './Navigation.astro';
import GitHubButton from './GitHubButton.astro';
import NButton from './NButton.astro';
import SearchButton from '../SearchButton.astro';
import ThemeToggle from '../ThemeToggle.astro';
import SmartImage from '@components/SmartImage.astro';
import { Icon } from 'astro-icon/components';

interface Props {
	platformQuery?: string;
}

const { platformQuery = '' } = Astro.props;
---

<div class="logo-burger">
	<a href="https://u24.gov.ua/" target="_blank" class="support-ukraine">
		<SmartImage
			src="/src/assets/images/support-ukraine-banner.webp"
			alt="Stand with Ukraine flag"
			width="48"
			height="31"
		/>
	</a>
	<a href="/" class="logo" aria-label="Link to homepage"></a>
	<div class="burger-group">
		<div class="icon-buttons">
			<ThemeToggle />
			<SearchButton />
		</div>
		<div class="divider"></div>
		<button onclick="Burger()" class="burger" aria-label="Burger menu">
			<Icon name="tabler:menu-2" class="icon-open" />
			<Icon name="tabler:x" class="icon-close" />
		</button>
	</div>
	<GitHubButton />
</div>

<Navigation platformQuery={platformQuery} />
<div class="head-buttons">
	<div class="icon-buttons">
		<ThemeToggle />
		<SearchButton />
	</div>
	<div class="divider"></div>
	<NButton id="Menu_Pricing" href="/pricing/" variant="text" class="price gtm_button"
		>Pricing</NButton
	>
	<NButton id="Menu_TryItNow" href="/installations/" variant="filled" class="try gtm_button"
		>Try it now</NButton
	>
</div>

<script>
	// Burger menu toggle
	function Burger() {
		const header = document.querySelector('header.header');
		const body = document.body;

		if (header?.classList.contains('opened-burger')) {
			header.classList.remove('opened-burger');
			const subMenus = document.querySelectorAll(
				'nav.head-menu > ul > li > div.centered-sub > ul.sub-menu'
			);
			subMenus.forEach((menu) => menu.classList.remove('open-sub'));
			body.style.overflow = '';
		} else {
			header?.classList.add('opened-burger');
			body.style.overflow = 'hidden';
		}
	}

	// Make function available globally
	(window as any).Burger = Burger;
</script>

<style lang="scss" is:global>
	@use '../../styles/variables' as *;

	header.header {
		position: fixed;
		top: 0;
		left: 0;
		transition-duration: 0.3s;
		width: 100%;
		height: $header-height;
		z-index: 8888;
		border-bottom: none;
		background-color: var(--sl-color-bg-sidebar);
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 0 20px;


		.logo-burger {
			position: relative;
			display: flex;
			height: 100%;
			align-items: center;
			gap: 0.875rem;
		}

		.head-buttons {
			display: flex;
			flex-direction: row;
			align-items: center;
			gap: 0.875rem;

			.icon-buttons {
				display: flex;
				align-items: center;
				gap: 0;
			}

			.divider {
				width: 1px;
				height: 32px;
				background-color: var(--sl-color-hairline-light);
				flex-shrink: 0;

				@media screen and (min-width: 1281px) and (max-width: 1499px) {
					display: none;
				}
			}

			.n-button {
				width: 90px;
				padding: 0;
				display: flex;
				align-items: center;
				justify-content: center;

				@media screen and (min-width: 1500px) {
					width: 110px;
				}

				&.price {
					color: var(--sl-color-white);
				}
			}
		}

		.support-ukraine {
			display: flex;
			align-items: center;
			img {
				height: 31px;
			}
		}

		.logo {
			position: relative;
			display: block;
			width: 140px;
			height: 60px;
			background-image: url(https://img.thingsboard.io/thingsboard_logo_b.svg);
			background-size: contain;
			background-position: center center;
			background-repeat: no-repeat;

			[data-theme='dark'] & {
				filter: invert(100%) sepia(68%) saturate(0%) hue-rotate(350deg) brightness(113%)
					contrast(101%);
			}

			@media screen and (min-width: 1025px) {
				width: 180px;
			}
		}
	}

	.burger-group {
		position: absolute;
		top: 50%;
		transform: translateY(-50%);
		right: 0;
		display: none;
		align-items: center;
		gap: 0.875rem;

		.icon-buttons {
			display: flex;
			align-items: center;
			gap: 0;
		}

		.divider {
			width: 1px;
			height: 32px;
			background-color: var(--sl-color-hairline-light);
			flex-shrink: 0;
		}
	}

	.burger {
		display: none;
		border: none;
		background: none;
		padding: 0;
		cursor: pointer;
		color: inherit;
		width: 32px;
		height: 32px;
		align-items: center;
		justify-content: center;

		svg {
			width: 28px;
			height: 28px;
		}

		.icon-close {
			display: none;
		}

		&:focus {
			outline: none;
		}
	}

	.opened-burger .burger {
		.icon-open {
			display: none;
		}

		.icon-close {
			display: block;
		}
	}

	// Responsive styles
	@media screen and (max-width: 1280px) {
		header.header {
			display: unset;
			height: unset !important;
			transition-property: height;

			.logo-burger {
				height: $header-height;
			}

			&.opened-burger {
				height: 100% !important;
				z-index: 10000;
				display: flex !important;
				flex-direction: column;
				align-items: stretch;

				.logo-burger {
					box-shadow: 0 1px 0 rgba(48, 86, 128, 0.07);
					flex-shrink: 0;
				}

				.head-buttons {
					display: flex;
					flex-shrink: 0;
					gap: 0.875rem;
					padding: 20px 0;

					.icon-buttons {
						display: none;
					}

					.divider {
						display: none;
					}

					.n-button {
						display: flex;
						margin: 0;
						width: 110px;
					}
				}
			}

			.burger-group {
				display: flex;
			}

			.burger {
				display: flex;
			}

			.head-buttons {
				display: none;
			}

			.n-button {
				display: none;
			}
		}
	}

	// ============================================
	// PAGE-SPECIFIC HEADER STYLES
	// ============================================

	// Landing pages with transparent header
	#home,
	#thingsboard-paas,
	#thingsboard-pe,
	#thingsboard-edge,
	#mqtt-broker {
		header.header {
			background-color: transparent;
			box-shadow: none;

			.support-ukraine p {
				color: $color-white;
			}

			.logo,
			.burger {
				filter: invert(100%) sepia(68%) saturate(0%) hue-rotate(350deg) brightness(113%)
					contrast(101%);
			}

			.burger {
				color: $color-black;
			}

			.divider {
				display: none;
			}

			.n-button {
				width: 110px;

				&.price {
					color: $color-white;
					transition-duration: 0s;
					border: none;
					background-color: rgba(255, 255, 255, 0.05);

					&:hover {
						text-decoration: none;
						color: $color-text-primary;
						background-color: $color-white;
					}
				}

				&.try {
					background-color: $color-primary;
					color: $color-white;

					&:hover {
						color: $color-primary;
						box-shadow: none;
						background-color: $color-white;
					}
				}
			}
		}
	}

	// Scrolled header state (flip-nav)
	#home,
	#thingsboard-paas,
	#thingsboard-pe,
	#trendz,
	#partners,
	#thingsboard-edge,
	#mqtt-broker,
	#pricing {
		&.flip-nav header.header {
			transition: all $transition-base;
			background-color: $color-white;
			box-shadow: var(--shadow-header);

			.support-ukraine p {
				color: $color-black;
			}

			.logo,
			.burger {
				filter: none;
			}

			.n-button {
				&.price {
					border: 1px solid $color-border;
					color: $color-text-primary;
					background-color: transparent;

					&:hover {
						border: 2px solid $color-text-primary;
					}
				}

				&.try {
					background-color: $color-primary;
					color: $color-white;

					&:hover {
						background-color: $color-primary;
						color: $color-white;
						box-shadow: var(--shadow-primary);
					}
				}
			}
		}
	}

	// Mobile burger opened state for landing pages
	#home,
	#docs,
	#common,
	#thingsboard-paas,
	#thingsboard-pe,
	#trendz,
	#thingsboard-edge,
	#mqtt-broker {
		header.header.opened-burger {
			transition: all $transition-base;
			background-color: $color-white;
			box-shadow: var(--shadow-header);

			.support-ukraine p {
				color: $color-black;
			}

			.logo,
			.burger {
				filter: none;
			}

			.head-menu ul {
				a,
				a:not([href]),
				span.main-menu-link {
					color: $color-text-primary;
				}

				li:hover a,
				li:hover span.main-menu-link {
					color: $color-primary;
				}
			}

			.n-button {
				&.price {
					border: 1px solid $color-border;
					color: $color-text-primary;
					background-color: transparent;

					&:hover {
						border: 2px solid $color-text-primary;
					}
				}

				&.try {
					background-color: $color-primary;
					color: $color-white;

					&:hover {
						background-color: $color-primary;
						color: $color-white;
						box-shadow: var(--shadow-primary);
					}
				}
			}
		}
	}

	// Hide search and theme toggle on landing pages
	#home,
	#thingsboard-paas,
	#thingsboard-pe,
	#trendz,
	#partners,
	#thingsboard-edge,
	#mqtt-broker,
	#pricing,
	#docs,
	#common {
		search-button,
		theme-toggle {
			display: none;
		}
	}

	// Show theme toggle on 404 page
	#common {
		theme-toggle {
			display: flex;
		}
	}

	// Show header border only on docs and 404 pages
	html:not([id]),
	#common {
		header.header {
			border-bottom: 1px solid var(--sl-color-hairline-shade);
		}
	}

	// Starlight mobile sidebar: 90% width, toggle button left when closed / right edge when open
	@media (max-width: 50rem) {
		#starlight__sidebar {
			width: 90%;
		}

		starlight-menu-button button {
			inset-inline-end: auto;
			inset-inline-start: var(--sl-nav-pad-x);
			top: calc(var(--header-height) + 0.75rem);
		}

		starlight-menu-button[aria-expanded='true'] button {
			inset-inline-start: 90%;
		}
	}
</style>
