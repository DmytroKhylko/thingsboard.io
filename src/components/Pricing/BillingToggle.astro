---
import { Icon } from 'astro-icon/components';

interface Props {
	leftLabel: string;
	rightLabel: string;
	leftValue: string;
	rightValue: string;
	id: string;
	leftGtmId?: string;
	rightGtmId?: string;
	leftFaqId?: string;
	leftFaqTooltip?: string;
	leftAutoTooltip?: boolean;
	rightFaqId?: string;
	rightFaqTooltip?: string;
	rightAutoTooltip?: boolean;
}

const { leftLabel, rightLabel, leftValue, rightValue, id, leftGtmId, rightGtmId, leftFaqId, leftFaqTooltip, leftAutoTooltip, rightFaqId, rightFaqTooltip, rightAutoTooltip } = Astro.props;
---

<div class="billing-toggle" data-toggle-id={id}>
	<span class={`billing-toggle-label${leftGtmId ? ' gtm_button' : ''} active`} id={leftGtmId} data-value={leftValue}>
		{leftLabel}
		{leftFaqId && (
			<span class="plan-feature-info" data-faq-id={leftFaqId}>
				<Icon name="tabler:info-circle" class="plan-feature-info-icon" />
				{leftFaqTooltip && (
					<span class="plan-feature-tooltip">
						<span class="plan-feature-tooltip-arrow"></span>
						<span class="plan-feature-tooltip-body" set:html={leftFaqTooltip + (leftAutoTooltip ? ' <span class="plan-feature-tooltip-readmore">read more</span>' : '')} />
					</span>
				)}
			</span>
		)}
	</span>
	<label class="billing-toggle-switch">
		<input type="checkbox" data-billing-toggle={id} role="switch" aria-label={`Toggle between ${leftLabel} and ${rightLabel}`} />
		<span class="billing-toggle-slider"></span>
	</label>
	<span class={`billing-toggle-label${rightGtmId ? ' gtm_button' : ''}`} id={rightGtmId} data-value={rightValue}>
		{rightLabel}
		{rightFaqId && (
			<span class="plan-feature-info" data-faq-id={rightFaqId}>
				<Icon name="tabler:info-circle" class="plan-feature-info-icon" />
				{rightFaqTooltip && (
					<span class="plan-feature-tooltip">
						<span class="plan-feature-tooltip-arrow"></span>
						<span class="plan-feature-tooltip-body" set:html={rightFaqTooltip + (rightAutoTooltip ? ' <span class="plan-feature-tooltip-readmore">read more</span>' : '')} />
					</span>
				)}
			</span>
		)}
	</span>
</div>

<style lang="scss" is:global>
	@use '../../styles/variables' as *;

	.billing-toggle {
		display: flex;
		align-items: center;
		gap: $spacing-3;
		margin-bottom: $spacing-6;
	}

	.billing-toggle-label {
		font-size: $font-size-sm;
		font-weight: $font-weight-medium;
		color: var(--color-text-secondary);
		cursor: pointer;
		transition: color $transition-fast;
		user-select: none;

		&.active {
			color: var(--color-text);
			font-weight: $font-weight-semibold;
		}
	}

	.billing-toggle-switch {
		position: relative;
		display: inline-block;
		width: 44px;
		height: 24px;
		cursor: pointer;

		input {
			opacity: 0;
			width: 0;
			height: 0;
		}
	}

	.billing-toggle-slider {
		position: absolute;
		inset: 0;
		background-color: var(--color-primary);
		border-radius: $radius-full;
		transition: background-color $transition-fast;

		&::before {
			content: '';
			position: absolute;
			width: 18px;
			height: 18px;
			left: 3px;
			bottom: 3px;
			background: var(--color-bg-surface);
			border-radius: 50%;
			transition: transform $transition-fast;
		}
	}

	.billing-toggle-switch input:checked + .billing-toggle-slider::before {
		transform: translateX(20px);
	}
</style>
