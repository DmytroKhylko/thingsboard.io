---
import { Icon } from 'astro-icon/components';
import type { PerpetualBenefit } from '@data/pricing/types.ts';

interface Props {
	title?: string;
	benefits: PerpetualBenefit[];
}

const { title = 'Why choose a Perpetual License?', benefits } = Astro.props;
---

<div class="perpetual-benefits-section">
	<h3 class="perpetual-benefits-title">{title}</h3>
	<div class="perpetual-benefits-grid">
		{benefits.map((b) => (
			<div class="perpetual-benefit">
				<div class="perpetual-benefit-head">
					{b.icon && (
						<Icon name={b.icon} class="perpetual-benefit-icon" />
					)}
					<h4 class="perpetual-benefit-heading">{b.title}</h4>
				</div>
				<p class="perpetual-benefit-desc">{b.description}</p>
			</div>
		))}
	</div>
</div>

<style lang="scss" is:global>
	@use '../../styles/variables' as *;

	.perpetual-benefits-section {
		margin-bottom: $spacing-8;
	}

	.perpetual-benefits-title {
		@include subsection-title;
		color: var(--color-text);
		margin: 0 0 $spacing-6;
	}

	.perpetual-benefits-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: $spacing-4;

		@include media-down(md) {
			grid-template-columns: 1fr;
		}
	}

	.perpetual-benefit {
		padding: $spacing-6;
		background: var(--color-bg-surface);
		border: 1px solid var(--sl-color-gray-5);
		border-radius: $radius-lg;
	}

	.perpetual-benefit-head {
		display: flex;
		align-items: center;
		gap: $spacing-2;
		margin-bottom: $spacing-2;
	}

	.perpetual-benefit-icon {
		width: 20px;
		height: 20px;
		color: var(--color-primary);
		flex-shrink: 0;
	}

	.perpetual-benefit-heading {
		font-size: $font-size-base;
		font-weight: $font-weight-semibold;
		color: var(--color-text);
		margin: 0;
	}

	.perpetual-benefit-desc {
		font-size: $font-size-sm;
		color: var(--color-text-secondary);
		margin: 0;
		line-height: 1.5;
	}
</style>
