---
import { Icon } from 'astro-icon/components';
import NButton from '../Landing/NButton.astro';
import PlanFeatureItem from './PlanFeatureItem.astro';
import type { PlanCard as PlanCardType } from '@data/pricing/types';

interface Props {
	plan: PlanCardType;
}

const { plan } = Astro.props;

function formatPrice(price: number | null, currency: string): string {
	if (price === null) return 'Custom';
	if (price === 0) return `${currency}0`;
	return `${currency}${price.toLocaleString('en-US').replace(/,/g, ' ')}`;
}
---

<div class={`plan-card ${plan.popular ? 'plan-card--popular' : ''}`} data-monthly-price={plan.price ?? ''} data-annual-price={plan.annualPrice ?? ''}>
	{plan.popular && <span class="plan-card-badge">POPULAR</span>}
	<div class="plan-card-header">
		<h3 class="plan-card-name">{plan.name}</h3>
		<p class="plan-card-description">{plan.description}</p>
	</div>
	<div class="plan-card-price">
		<span class="plan-card-amount">{formatPrice(plan.price, plan.currency)}</span>
		{plan.price !== null && <span class="plan-card-period">{plan.period}</span>}
		{plan.priceFaqId && (
			<span class="plan-feature-info" data-faq-id={plan.priceFaqId}>
				<Icon name="tabler:info-circle" class="plan-feature-info-icon" />
				{plan.priceFaqTooltip && (
					<span class="plan-feature-tooltip">
						<span class="plan-feature-tooltip-arrow"></span>
						<span class="plan-feature-tooltip-body">
							<span>{plan.priceFaqTooltip}</span>
							<span class="plan-feature-tooltip-readmore"> read more</span>
						</span>
					</span>
				)}
			</span>
		)}
	</div>
	<NButton
		href={plan.ctaHref}
		variant={plan.ctaPrimary ? 'filled' : 'outlined'}
		size="sm"
		fullWidth
		target={plan.ctaHref.startsWith('http') ? '_blank' : undefined}
		id={plan.gtmId}
		class={`plan-card-cta${plan.gtmId ? ' gtm_button' : ''}`}
		data-product-id={plan.productId}
		data-plan-id={plan.planId}
	>
		{plan.ctaText}
	</NButton>
	<div class="plan-card-features">
		{plan.features.map((feature) => (
			<PlanFeatureItem feature={feature} />
		))}
	</div>
</div>

<style lang="scss" is:global>
	@use '../../styles/variables' as *;

	.plan-card {
		position: relative;
		display: grid;
		grid-template-rows: subgrid;
		grid-row: span 4; // header, price, CTA, features
		gap: $spacing-3;
		padding: 20px 12px;
		background: var(--color-bg-surface);
		border: 1px solid var(--sl-color-gray-5);
		border-radius: $radius-xl;
		min-width: 0;

		&--popular {
			border: 1.5px solid var(--color-primary);
			z-index: 1;

			// Taller than siblings, no horizontal overflow
			margin: -10px 0;
			padding: calc(20px + 10px) 12px;
		}
	}

	.plan-card-badge {
		position: absolute;
		top: 12px;
		right: 12px;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 5px $spacing-3 4px;
		background: var(--color-primary);
		color: #fff;
		font-size: 10px;
		font-weight: $font-weight-bold;
		letter-spacing: 0.5px;
		line-height: 1;
		border-radius: $radius-sm;
		white-space: nowrap;

		[data-theme='dark'] & {
			color: #000;
		}
	}

	.plan-card-header {
		// No margin — subgrid row gap handles spacing
	}

	.plan-card-name {
		font-size: $font-size-2xl;
		font-weight: $font-weight-semibold;
		color: var(--color-text);
		margin: 0 0 $spacing-1;
	}

	.plan-card-description {
		font-size: $font-size-xs;
		color: var(--color-text-secondary);
		margin: 0;
		line-height: 1.4;
	}

	.plan-card-price {
		display: flex;
		align-items: baseline;
		justify-content: center;
		gap: $spacing-1;
		padding: $spacing-2 0;
	}

	.plan-card-amount {
		font-size: 2rem;
		font-weight: 700;
		color: var(--color-text);
		line-height: 1;

		@include media-down(sm) {
			font-size: 1.5rem;
		}
	}

	.plan-card-period {
		font-size: $font-size-sm;
		color: var(--color-text-secondary);
	}

	.plan-card-cta {
		// No margin — subgrid row gap handles spacing
		align-self: start;
	}

	.plan-card-features {
		display: flex;
		flex-direction: column;
		gap: 2px;
		flex: 1;
	}
</style>
