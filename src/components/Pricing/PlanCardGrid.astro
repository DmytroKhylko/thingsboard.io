---
import PlanCard from './PlanCard.astro';
import type { PlanCard as PlanCardType } from '@data/pricing/types';

interface Props {
	plans: PlanCardType[];
	class?: string;
}

const { plans, class: className } = Astro.props;
---

<div class={`plan-card-grid ${className || ''}`} style={`--plan-count: ${plans.length}`}>
	{plans.map((plan) => (
		<PlanCard plan={plan} />
	))}
	<slot />
</div>

<style lang="scss" is:global>
	@use '../../styles/variables' as *;

	.plan-card-grid {
		display: grid;
		grid-template-columns: repeat(var(--plan-count, 5), 1fr);
		// 4 row tracks per card row (header, price, CTA, features) for subgrid alignment
		grid-template-rows: auto auto auto 1fr;
		gap: $spacing-3;
		margin-bottom: $spacing-16;

		@include media-down(lg) {
			grid-template-columns: repeat(2, 1fr);
			grid-template-rows: auto;

			.plan-card {
				grid-row: span 1;
				display: flex;
				flex-direction: column;
				gap: $spacing-4;
				padding: $spacing-6 $spacing-5;

				&--popular {
					margin: 0;
					padding: $spacing-6 $spacing-5;
				}
			}



			.upsell-card {
				grid-column: auto;
				flex-direction: column;
				align-items: center;
				justify-content: center;
				text-align: center;
				padding: $spacing-6 $spacing-5;
				margin-top: 0;
			}
		}

		@include media-down(sm) {
			grid-template-columns: 1fr;

			.plan-card {
				padding: $spacing-6;

				&--popular {
					padding: $spacing-6;
				}
			}
		}
	}
</style>
