---
import { Icon } from 'astro-icon/components';
import type { PlanFeature } from '@data/pricing/types.ts';

interface Props {
	feature: PlanFeature;
}

const { feature } = Astro.props;

const classes = [
	'plan-feature',
	feature.highlight && 'plan-feature--highlight',
	feature.noIcon && 'plan-feature--no-icon',
	feature.faqTooltip && 'plan-feature--faq',
].filter(Boolean).join(' ');
---

<div class={classes}>
	{!feature.noIcon && (
		<span class="plan-feature-icon">
			{feature.plusIcon ? (
				<Icon name="tabler:plus" />
			) : (
				<Icon name="tabler:check" />
			)}
		</span>
	)}
	<span class="plan-feature-text">
		<span set:html={feature.text} />{(feature.faqTooltip || feature.faqId) && (
			<span class="plan-feature-info" data-faq-id={feature.faqId}>
				<Icon name="tabler:info-circle" class="plan-feature-info-icon" />
				{feature.faqTooltip && (
					<span class="plan-feature-tooltip">
						<span class="plan-feature-tooltip-arrow"></span>
						<span class="plan-feature-tooltip-body" set:html={feature.faqTooltip} />
					</span>
				)}
			</span>
		)}
	</span>
</div>

<style lang="scss" is:global>
	@use '../../styles/variables' as *;

	.plan-feature {
		display: flex;
		align-items: flex-start;
		gap: 4px;
		font-size: $font-size-sm;
		color: var(--color-text);
		padding: 3px 0;
		line-height: 1.4;
		min-height: 24px;

		&--highlight {
			.plan-feature-text {
				font-weight: $font-weight-semibold;
				color: var(--color-text);
			}
		}

		&--no-icon {
			min-height: 24px;
		}
	}

	.plan-feature-icon {
		flex-shrink: 0;
		display: flex;
		align-items: center;
		width: 14px;
		margin-top: 2px;

		[data-icon] {
			width: 14px;
			height: 14px;
			color: var(--color-primary);
		}
	}

	.plan-feature-text {
		flex: 1;
		min-width: 0;
	}

	// ─── Feature info icon + tooltip ───
	.plan-feature-info {
		position: relative;
		display: inline;
		cursor: pointer;
		margin-left: 0;
	}

	.plan-feature-info-icon {
		width: 14px;
		height: 14px;
		color: var(--color-text);
		opacity: 0.8;
		vertical-align: text-top;
		margin-top: -1px;
		transition: color 0.2s ease, opacity 0.2s ease;
	}

	.plan-feature-info:hover .plan-feature-info-icon {
		color: var(--color-primary);
		opacity: 1;
	}

	.plan-feature-tooltip {
		position: fixed;
		z-index: 99999;
		pointer-events: none;
		left: -9999px;
		top: 0;
		display: flex;
		align-items: center;

		opacity: 0;
		visibility: hidden;
		transition: opacity 0.15s ease, visibility 0.15s ease;
		transition-delay: 0ms;

		// Invisible bridge from icon to tooltip body so hover is maintained across the gap
		&::before {
			content: '';
			position: absolute;
			top: 0;
			left: -12px;
			width: 16px;
			height: 100%;
		}
	}

	.plan-feature-tooltip.pricing-tooltip--visible {
		opacity: 1;
		visibility: visible;
		pointer-events: none;
		&.pricing-tooltip--interactive { pointer-events: auto; }
	}

	.plan-feature-tooltip-arrow {
		flex-shrink: 0;
		width: 0;
		height: 0;
		border: 6px solid transparent;
		border-right-color: var(--sl-color-gray-5);
		position: relative;

		&::after {
			content: '';
			position: absolute;
			top: -6px;
			left: -4px;
			width: 0;
			height: 0;
			border: 6px solid transparent;
			border-right-color: var(--color-bg-surface);
		}
	}

	// Flipped arrow (tooltip to the left of icon — arrow points right)
	.pricing-tooltip--flipped {
		flex-direction: row-reverse;

		.plan-feature-tooltip-arrow,
		.addon-tooltip-arrow,
		.comparison-tooltip-arrow,
		.sub-tab-tooltip-arrow {
			border-right-color: transparent;
			border-left-color: var(--sl-color-gray-5);

			&::after {
				left: auto;
				right: -4px;
				border-right-color: transparent !important;
				border-left-color: var(--color-bg-surface);
			}
		}

		// Bridge on the right side
		&::before {
			left: auto;
			right: -12px;
		}
	}

	.plan-feature-tooltip-readmore {
		color: var(--color-primary);
		cursor: pointer;

		&:hover {
			text-decoration: underline;
		}
	}

	.plan-feature-tooltip-body {
		display: block;
		padding: $spacing-3;
		background: var(--color-bg-surface);
		color: var(--color-text);
		font-size: $font-size-sm;
		font-weight: $font-weight-normal;
		line-height: 1.5;
		text-align: left;
		white-space: normal;
		width: 280px;
		border-radius: $radius-lg;
		border: 1px solid var(--sl-color-gray-5);
		box-shadow: 0 12px 32px rgba(0, 0, 0, 0.12);

		a {
			color: var(--color-primary);
			text-decoration: none;

			&:hover {
				text-decoration: underline;
			}
		}
	}

</style>
