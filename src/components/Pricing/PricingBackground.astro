---
// Diagonal animated wave background — upper-left to bottom-right, converging at bottom
// Uses SMIL <animateTransform> for correct SVG coordinate-space animation
// Light mode: blue waves on white; Dark mode: lighter waves on dark bg
---

<div class="pricing-bg" aria-hidden="true">
	<svg
		class="pricing-bg-svg"
		xmlns="http://www.w3.org/2000/svg"
		viewBox="0 0 900 900"
		preserveAspectRatio="xMaxYMid slice"
	>
		<defs>
			<radialGradient id="pbg-glow-1" cx="65%" cy="35%" r="55%">
				<stop offset="0%" stop-color="var(--pricing-wave-color)" stop-opacity="0.10" />
				<stop offset="100%" stop-color="var(--pricing-wave-color)" stop-opacity="0" />
			</radialGradient>
			<radialGradient id="pbg-glow-2" cx="45%" cy="70%" r="40%">
				<stop offset="0%" stop-color="var(--pricing-wave-color)" stop-opacity="0.06" />
				<stop offset="100%" stop-color="var(--pricing-wave-color)" stop-opacity="0" />
			</radialGradient>
		</defs>

		<!-- Static glow blobs -->
		<rect width="900" height="900" fill="url(#pbg-glow-1)" />
		<rect width="900" height="900" fill="url(#pbg-glow-2)" />

		<!--
			Wave A — large, very slow, rightmost
			Vertical sine: baseline x=700, amplitude 100, period 900
		-->
		<g>
			<animateTransform attributeName="transform" type="translate"
				from="0 0" to="0 -900" dur="40s" repeatCount="indefinite" />
			<path
				d="M700,0 C800,164 800,286 700,450 C600,614 600,736 700,900 C800,1064 800,1186 700,1350 C600,1514 600,1636 700,1800 L900,1800 L900,0Z"
				fill="var(--pricing-wave-color)"
				fill-opacity="0.055"
			/>
		</g>

		<!--
			Wave B — slow, mid-right, opposite direction
			Baseline x=550, amplitude 80, period 600
		-->
		<g>
			<animateTransform attributeName="transform" type="translate"
				from="0 -600" to="0 0" dur="28s" repeatCount="indefinite" />
			<path
				d="M550,0 C630,109 630,191 550,300 C470,409 470,491 550,600 C630,709 630,791 550,900 C470,1009 470,1091 550,1200 C630,1309 630,1391 550,1500 C470,1609 470,1691 550,1800 L900,1800 L900,0Z"
				fill="var(--pricing-wave-color)"
				fill-opacity="0.045"
			/>
		</g>

		<!--
			Wave C — medium, left-of-center
			Baseline x=380, amplitude 65, period 450
		-->
		<g>
			<animateTransform attributeName="transform" type="translate"
				from="0 0" to="0 -450" dur="18s" repeatCount="indefinite" />
			<path
				d="M380,0 C445,82 445,143 380,225 C315,307 315,368 380,450 C445,532 445,593 380,675 C315,757 315,818 380,900 C445,982 445,1043 380,1125 C315,1207 315,1268 380,1350 C445,1432 445,1493 380,1575 C315,1657 315,1718 380,1800 L900,1800 L900,0Z"
				fill="var(--pricing-wave-color)"
				fill-opacity="0.035"
			/>
		</g>

		<!--
			Wave D — very slow, largest, leftmost, opposite direction
			Baseline x=220, amplitude 120, period 900
		-->
		<g>
			<animateTransform attributeName="transform" type="translate"
				from="0 -900" to="0 0" dur="50s" repeatCount="indefinite" />
			<path
				d="M220,0 C340,164 340,286 220,450 C100,614 100,736 220,900 C340,1064 340,1186 220,1350 C100,1514 100,1636 220,1800 L900,1800 L900,0Z"
				fill="var(--pricing-wave-color)"
				fill-opacity="0.035"
			/>
		</g>
	</svg>
</div>

<style>
	.pricing-bg {
		--pricing-wave-color: #3369FF;

		position: fixed;
		inset: 0;
		z-index: -1;
		pointer-events: none;
		overflow: hidden;
		perspective: 1400px;
	}

	[data-theme='dark'] .pricing-bg {
		--pricing-wave-color: #6b9aff;
	}

	.pricing-bg-svg {
		position: absolute;
		right: -20%;
		top: -45%;
		width: 110%;
		height: 180%;
		overflow: visible;
		transform: rotate(-28deg) rotateY(-6deg);
		transform-origin: top right;
	}

	@media (prefers-reduced-motion: reduce) {
		.pricing-bg-svg {
			display: none;
		}
	}
</style>
