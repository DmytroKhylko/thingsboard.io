---

<div class="region-toggle">
	<span class="region-toggle-label gtm_button active" id="Pricing_PE_Cloud_NorthAmerica" data-region="na">North America</span>
	<label class="region-toggle-switch">
		<input type="checkbox" id="region-select" aria-label="Toggle region between North America and Europe" />
		<span class="region-toggle-slider"></span>
	</label>
	<span class="region-toggle-label gtm_button" id="Pricing_PE_Cloud_Europe" data-region="eu">Europe</span>
</div>

<style lang="scss" is:global>
	@use '../../styles/variables' as *;

	.region-toggle {
		display: flex;
		align-items: center;
		gap: $spacing-3;
		margin-bottom: $spacing-6;
	}

	.region-toggle-label {
		font-size: $font-size-sm;
		font-weight: $font-weight-medium;
		color: var(--color-text-secondary);
		cursor: pointer;
		transition: color $transition-fast;
		user-select: none;

		&.active {
			color: var(--color-text);
			font-weight: $font-weight-semibold;
		}
	}

	.region-toggle-switch {
		position: relative;
		display: inline-block;
		width: 44px;
		height: 24px;
		cursor: pointer;

		input {
			opacity: 0;
			width: 0;
			height: 0;
		}
	}

	.region-toggle-slider {
		position: absolute;
		inset: 0;
		background-color: var(--color-primary);
		border-radius: $radius-full;
		transition: background-color $transition-fast;

		&::before {
			content: '';
			position: absolute;
			width: 18px;
			height: 18px;
			left: 3px;
			bottom: 3px;
			background: var(--color-bg-surface);
			border-radius: 50%;
			transition: transform $transition-fast;
		}
	}

	.region-toggle-switch input:checked + .region-toggle-slider::before {
		transform: translateX(20px);
	}
</style>
