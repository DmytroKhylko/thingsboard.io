---
import { Icon } from 'astro-icon/components';
import type { TopUpGroup } from '../../data/pricing/types';

interface Props {
	title?: string;
	topUps: TopUpGroup[];
}

const { title = 'Top-ups', topUps } = Astro.props;
---

<div class="topups-section">
	<h3 class="topups-title">{title}</h3>
	<div class="topups-columns">
		{topUps.map((group) => (
			<div class="topups-column">
				<h4 class="topups-group-title">{group.title}</h4>
				<div class="topups-list">
					{group.items.map((item) => (
						<div class="topup-item">
							<button type="button" class="topup-header" aria-expanded="false">
								<span class="topup-name">{item.name}</span>
								<div class="topup-header-right">
									<span class="topup-price">
										<span class="topup-price-amount">
											{typeof item.priceUsd === 'string' ? item.priceUsd : `$${item.priceUsd}`}
										</span>
										{item.period && <span class="topup-period"> {item.period}</span>}
									</span>
									{item.details && item.details.length > 0 && (
										<Icon name="tabler:chevron-down" class="topup-chevron" />
									)}
								</div>
							</button>
							{item.details && item.details.length > 0 && (
								<div class="topup-details">
									<div class="topup-details-inner">
										{item.details.map((d) => (
											<div class="topup-detail-row">
												<span class="topup-detail-label">{d.label}</span>
												<span class="topup-detail-value">{d.value}</span>
											</div>
										))}
									</div>
								</div>
							)}
						</div>
					))}
				</div>
			</div>
		))}
	</div>
</div>

<style lang="scss" is:global>
	@use '../../styles/variables' as *;

	.topups-section {
		margin-bottom: $spacing-16;
	}

	.topups-title {
		@include subsection-title;
		color: var(--color-text);
		margin: 0 0 $spacing-6;
	}

	.topups-columns {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: $spacing-3;
		width: 100%;
		padding-left: 0;
		padding-right: 0;

		@include media-down(md) {
			grid-template-columns: 1fr;
			gap: $spacing-8;
		}
	}

	.topups-column {
		min-width: 0;
		padding-left: 0;
		padding-right: 0;
	}

	.topups-group-title {
		font-size: $font-size-lg;
		font-weight: $font-weight-semibold;
		color: var(--color-text);
		margin: 0 0 $spacing-3;
	}

	.topups-list {
		display: flex;
		flex-direction: column;
		gap: $spacing-2;
	}

	.topup-item {
		border: 1px solid var(--sl-color-gray-5);
		border-radius: $radius-lg;
		overflow: hidden;
		background: var(--color-bg-surface);

		&.expanded {
			.topup-chevron {
				transform: rotate(180deg);
			}

			.topup-details {
				max-height: 300px;
				opacity: 1;
			}
		}
	}

	.topup-header {
		width: 100%;
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: $spacing-3 $spacing-4;
		border: none;
		background: none;
		cursor: pointer;
		text-align: left;
		gap: $spacing-3;
		color: var(--color-text);
		transition: background-color 0.15s ease;

		&:hover {
			background-color: var(--color-bg-light);
		}
	}

	.topup-header-right {
		display: flex;
		align-items: center;
		gap: $spacing-3;
		flex-shrink: 0;
	}

	.topup-name {
		font-size: $font-size-sm;
		font-weight: $font-weight-medium;
	}

	.topup-price {
		font-size: $font-size-sm;
		white-space: nowrap;
	}

	.topup-price-amount {
		font-weight: $font-weight-bold;
		color: var(--color-primary);
	}

	.topup-period {
		font-weight: $font-weight-normal;
		color: var(--color-text-secondary);
	}

	.topup-chevron {
		width: 16px;
		height: 16px;
		color: var(--color-text-secondary);
		transition: transform 0.2s ease;
		flex-shrink: 0;
	}

	.topup-details {
		max-height: 0;
		opacity: 0;
		overflow: hidden;
		transition: max-height 0.3s ease, opacity 0.25s ease;
	}

	.topup-details-inner {
		padding: 0 $spacing-4 $spacing-3;
	}

	.topup-detail-row {
		display: flex;
		justify-content: space-between;
		padding: $spacing-2 0;
		font-size: $font-size-sm;

		&:not(:last-child) {
			border-bottom: 1px solid var(--sl-color-gray-5);
		}
	}

	.topup-detail-label {
		color: var(--color-text-secondary);
	}

	.topup-detail-value {
		font-weight: $font-weight-medium;
		color: var(--color-text);
	}
</style>
