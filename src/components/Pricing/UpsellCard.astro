---
import NButton from '../Landing/NButton.astro';

interface Props {
	heading: string;
	subtitle?: string;
	ctaText: string;
	/** Switch to this sub-tab section on click */
	targetSection?: string;
	/** JS function to call on click (e.g., "window.openTbPcCalc?.()") */
	onclick?: string;
}

const { heading, subtitle, ctaText, targetSection, onclick } = Astro.props;
---

<div class="upsell-card">
	<div class="upsell-card-text">
		<h3 class="upsell-card-heading">{heading}</h3>
		{subtitle && <p class="upsell-card-subtitle">{subtitle}</p>}
	</div>
	<NButton
		variant="filled"
		size="sm"
		class="upsell-card-btn"
		data-switch-to={targetSection}
		onclick={onclick}
	>
		{ctaText}
	</NButton>
</div>

<style lang="scss" is:global>
	@use '../../styles/variables' as *;

	.upsell-card {
		display: flex;
		flex-direction: row;
		align-items: center;
		justify-content: space-between;
		padding: $spacing-6 $spacing-8;
		background: var(--color-bg-surface);
		border: 1px solid var(--sl-color-gray-5);
		margin-top: $spacing-8;
		border-radius: $radius-xl;
		gap: $spacing-6;
		grid-column: 1 / -1;
		grid-row: span 1; // Override subgrid span from plan cards

		@include media-down(sm) {
			flex-direction: column;
			text-align: center;
			padding: $spacing-6;
		}
	}

	.upsell-card-text {
		min-width: 0;
	}

	.upsell-card-heading {
		font-size: $font-size-lg;
		font-weight: $font-weight-semibold;
		color: var(--color-text);
		margin: 0;
		line-height: 1.4;
	}

	.upsell-card-subtitle {
		font-size: $font-size-sm;
		color: var(--color-text-secondary);
		margin: $spacing-1 0 0;
		line-height: 1.4;
	}

	.upsell-card-btn {
		flex-shrink: 0;
		white-space: nowrap;
	}
</style>
