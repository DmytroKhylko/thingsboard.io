---
type Variant = 'pe' | 'ce';

interface Props {
	variant?: Variant;
}

const { variant = 'pe' } = Astro.props;
const defaultText = variant === 'ce' ? 'CE' : 'PE / Cloud only';
---

<span class:list={['product-badge', `product-badge--${variant}`]}>
	<slot>{defaultText}</slot>
</span>

<style>
	.product-badge {
		display: inline-block;
		padding: 3px 8px;
		border: 1px solid;
		border-radius: 20px;
		font-size: 0.75em;
		font-weight: 500;
		line-height: 1.2;
		white-space: nowrap;
	}

	.product-badge--pe {
		background: var(--color-light-blue-low);
		border-color: var(--color-light-blue);
		color: var(--color-light-blue-high);
	}

	.product-badge--ce {
		background: var(--sl-color-accent-low);
		border-color: var(--sl-color-accent);
		color: var(--sl-color-accent-high);
	}
</style>
