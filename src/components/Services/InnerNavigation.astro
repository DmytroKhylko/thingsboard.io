---
interface Tab {
	/** Unified ID — used as URL ?{paramName}= value and matches id="tab-{id}" content div */
	id: string;
	/** Display label */
	label: string;
	/** Optional icon path */
	icon?: string;
	/** Active by default */
	active?: boolean;
}

interface Props {
	tabs: Tab[];
	/** URL query param name, defaults to 'section' */
	paramName?: string;
}

const { tabs, paramName = 'section' } = Astro.props;
---

<nav class="inner-navigation" data-param={paramName}>
	<ul class="menu">
		{
			tabs.map((t) => (
				<li
					class:list={['menu-item', { 'tb-logo': !!t.icon }, { active: t.active }]}
					data-id={t.id}
					style={t.icon ? `--tab-icon: url('${t.icon}')` : undefined}
				>
					<a href="javascript:void(0);">{t.label}</a>
				</li>
			))
		}
	</ul>
</nav>
<div class="pricing-header-divider"></div>

<script>
	const nav = document.querySelector<HTMLElement>('.inner-navigation')!;
	const paramName = nav.dataset.param ?? 'section';
	const items = nav.querySelectorAll<HTMLElement>('.menu-item');

	function activateTab(id: string, pushState = true) {
		items.forEach((item) => item.classList.toggle('active', item.dataset.id === id));
		document.querySelectorAll<HTMLElement>('.tab-content').forEach((el) => {
			el.style.display = el.id === `tab-${id}` ? '' : 'none';
		});
		if (pushState) {
			const url = new URL(window.location.href);
			url.searchParams.set(paramName, id);
			history.pushState(null, '', url);
		}
	}

	// Init from URL param
	const urlValue = new URLSearchParams(window.location.search).get(paramName);
	if (urlValue) {
		const match = Array.from(items).find((item) => item.dataset.id === urlValue);
		if (match) activateTab(match.dataset.id!, false);
	}

	items.forEach((item) => {
		item.addEventListener('click', () => activateTab(item.dataset.id!));
	});
</script>

<style lang="scss">
	$blue: #2a7dec;

	.inner-navigation {
		position: relative;
		margin-top: 32px;
		margin-bottom: 24px;
		display: flex;
		justify-content: center;
		align-items: center;

		.menu {
			list-style: none;
			display: flex;
			flex-wrap: wrap;
			justify-content: center;
			align-items: center;
			margin: 0;
			padding: 0;
		}

		.menu-item {
			position: relative;
			display: table;
			padding: 6px;
			cursor: pointer;

			a {
				text-decoration: none;
				display: block;
				text-align: center;
				border: 1px solid rgba(0, 0, 0, 0.08);
				border-radius: 34px;
				font-size: 20px;
				line-height: 32px;
				color: #212529;
				font-weight: 400;
				padding: 8px 24px;
				letter-spacing: 1px;

				&:hover {
					border-color: #212529;
					border-width: 2px;
					margin: -1px;
				}

				&::before {
					display: inline-block;
					content: '';
					vertical-align: middle;
					margin-right: 6px;
					width: 27px;
					height: 27px;
				}
			}

			&.tb-logo a::before {
				background: var(--tab-icon) no-repeat center;
				background-size: contain;
				filter: invert(11%) sepia(10%) saturate(825%) hue-rotate(169deg) brightness(93%)
					contrast(90%);
			}

			&.active {
				z-index: 5;

				a {
					color: $blue;
					border-color: $blue;
					box-shadow: 0 18px 16px -10px rgba(42, 125, 236, 0.25);

					&:hover {
						box-shadow: 0 18px 16px -15px rgba(42, 125, 236, 0.25);
						border-color: $blue;
						border-width: 1px;
						margin: unset;
					}
				}

				&.tb-logo a::before {
					filter: brightness(0) saturate(100%) invert(37%) sepia(91%) saturate(1415%)
						hue-rotate(199deg) brightness(94%) contrast(96%);
				}
			}
		}
	}

	.pricing-header-divider {
		height: 3px;
		width: 100%;
		background-color: #102a4e;
		margin-top: 24px;
	}
</style>