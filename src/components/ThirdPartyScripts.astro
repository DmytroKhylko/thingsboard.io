---
import DeferredLoadTrigger from './DeferredLoadTrigger.astro';
import GtmHead from './GtmHead.astro';
import YourGptWidget from './YourGptWidget.astro';
---

<!--
	Single entry point for all third-party browser scripts (GTM + YourGPT
	chatbot). Order matters: DeferredLoadTrigger MUST come first so the global
	window.__deferOnInteraction exists when the consumer scripts parse. Both
	BaseLayout and the Starlight Head override mount this in <head>, so the
	docs site gets the same loaders as the marketing site.
-->
<DeferredLoadTrigger />
<GtmHead />
<YourGptWidget />
