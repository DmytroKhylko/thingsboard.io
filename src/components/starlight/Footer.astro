---
import DefaultFooter from '@astrojs/starlight/components/Footer.astro';
import SocialNetworks from '~/components/Landing/SocialNetworks.astro';

const currentYear = new Date().getFullYear();
---

<DefaultFooter />

<div class="doc-footer sl-markdown-content">
	<nav>
		<a href="/docs/getting-started-guides/helloworld/">Get Started</a>
		<a href="/docs/">Documentation</a>
		<a href="/iot-use-cases/">Use cases</a>
		<a href="/blog/">Blog</a>
		<a href="/services/">Services</a>
		<a href="/docs/contact-us/">Contact us</a>
	</nav>
	<div class="deepmost">
		<div class="copyright">&copy; {currentYear} The ThingsBoard Authors</div>
		<SocialNetworks />
	</div>
</div>

<style>
	@media (min-width: 72rem) {
		:global([data-has-toc]) .hide-when-toc-is-visible {
			display: none;
		}
	}

	.doc-footer {
		border-top: 1px solid var(--sl-color-hairline);
		padding: var(--sl-content-pad-x) 0;
	}

	nav {
		display: flex;
		flex-wrap: wrap;
		gap: 0 1.75rem;
		margin-bottom: 1rem;
	}

	nav a {
		font-size: 1rem;
		color: var(--sl-color-text);
		text-decoration: none;
		white-space: nowrap;
	}

	nav a:hover {
		color: var(--sl-color-white);
	}

	.deepmost {
		display: flex;
		justify-content: space-between;
		align-items: center;
		flex-wrap: wrap;
		gap: 0.5rem;
		--sn-color: var(--sl-color-gray-3);
	}

	.copyright {
		font-size: 0.875rem;
		color: var(--sl-color-gray-3);
	}
</style>
