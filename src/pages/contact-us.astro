---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.astro';
---

<BaseLayout title="Contact Us" description="Contact ThingsBoard team" pageId="contact-us">
	<div class="contact-us-page">
		<ContactForm mode="page" />
	</div>
</BaseLayout>

<style lang="scss">
	.contact-us-page {
		min-height: calc(100vh - var(--header-height, 72px));
		background-color: #f4f8fe;
		background-image: url('/images/contact-us-bg.svg');
		background-position: center;
		background-repeat: no-repeat;
		background-size: contain;
		padding-top: var(--header-height, 72px);

		// In dark mode the brand-blue dotted SVG is fine on a dark page bg
		// (transparent background, themed strokes), but the page surface must
		// switch to a dark tone so the form card has contrast.
		:global([data-theme='dark']) & {
			background-color: var(--color-bg);
		}
	}
</style>
