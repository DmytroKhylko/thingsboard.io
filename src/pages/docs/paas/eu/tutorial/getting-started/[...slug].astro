---
/**
 * Redirects old /docs/paas/eu/tutorial/getting-started/[...slug] URLs
 * to the new /docs/paas/eu/getting-started/[...slug] structure.
 */
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
	const docs = await getCollection('docs');
	const entries = docs.filter(
		(e) =>
			e.id === 'docs/paas/eu/getting-started' ||
			e.id.startsWith('docs/paas/eu/getting-started/')
	);

	return entries.map((entry) => {
		const slug =
			entry.id === 'docs/paas/eu/getting-started'
				? undefined
				: entry.id.replace(/^docs\/paas\/eu\/getting-started\//, '');
		return { params: { slug } };
	});
}

const { slug } = Astro.params;
const target = slug
	? `/docs/paas/eu/getting-started/${slug}/`
	: '/docs/paas/eu/getting-started/';

return Astro.redirect(target, 301);
---
