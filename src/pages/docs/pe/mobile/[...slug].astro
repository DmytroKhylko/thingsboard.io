---
/**
 * Redirects old /docs/pe/mobile/[...slug] URLs to the new /docs/mobile/pe/[...slug] structure.
 * Uses getStaticPaths so Astro generates a static redirect page for every existing
 * docs/mobile/pe/* content entry — including new pages added in the future.
 *
 * Starlight's docsLoader() generates entry IDs without a trailing slash for index files:
 *   src/content/docs/docs/mobile/pe/index.mdx  →  id: "docs/mobile/pe"
 *   src/content/docs/docs/mobile/pe/some-page.mdx  →  id: "docs/mobile/pe/some-page"
 */
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
	const docs = await getCollection('docs');
	const entries = docs.filter(
		(e) => e.id === 'docs/mobile/pe' || e.id.startsWith('docs/mobile/pe/')
	);

	return entries.map((entry) => {
		const slug =
			entry.id === 'docs/mobile/pe' ? undefined : entry.id.replace(/^docs\/mobile\/pe\//, '');
		return { params: { slug } };
	});
}

return Astro.redirect(Astro.params.slug ? `/docs/mobile/pe/${Astro.params.slug}/` : '/docs/mobile/pe/', 301);
---
