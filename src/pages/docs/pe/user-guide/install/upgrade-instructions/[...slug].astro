---
/**
 * Redirects old /docs/pe/user-guide/install/upgrade-instructions/{platform}/{familySlug}
 * to new /docs/pe/installation/upgrade-instructions/{platform}/{familySlug}.
 */
import { UPGRADE_FAMILIES, getFamilySlug } from '~/models/upgrade-instructions';

export function getStaticPaths() {
	const platforms = ['ubuntu', 'centos', 'windows', 'docker', 'docker-compose'];
	const paths = [];
	for (const family of UPGRADE_FAMILIES) {
		const familySlug = getFamilySlug(family);
		for (const platform of platforms) {
			paths.push({
				params: { slug: `${platform}/${familySlug}` },
				props: { target: `/docs/pe/installation/upgrade-instructions/${platform}/${familySlug}/` },
			});
		}
	}
	return paths;
}

const { target } = Astro.props as { target: string };
return Astro.redirect(target, 301);
---
