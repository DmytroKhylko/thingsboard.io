---
import { RELEASE_FAMILIES, familySlug } from '~/models/releases-table';

export function getStaticPaths() {
	return RELEASE_FAMILIES.map((f) => ({
		params: { familySlug: familySlug(f.family) },
	}));
}

return Astro.redirect(`/docs/pe/releases/releases-table/${Astro.params.familySlug}/`, 301);
---
