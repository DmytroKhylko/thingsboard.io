---
/**
 * Redirects old /docs/tutorial/getting-started/[...slug] URLs
 * to the new /docs/getting-started/[...slug] structure.
 */
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
	const docs = await getCollection('docs');
	const entries = docs.filter(
		(e) => e.id === 'docs/getting-started' || e.id.startsWith('docs/getting-started/')
	);

	return entries.map((entry) => {
		const slug =
			entry.id === 'docs/getting-started'
				? undefined
				: entry.id.replace(/^docs\/getting-started\//, '');
		return { params: { slug } };
	});
}

const { slug } = Astro.params;
const target = slug ? `/docs/getting-started/${slug}/` : '/docs/getting-started/';

return Astro.redirect(target, 301);
---
