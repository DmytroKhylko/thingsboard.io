---
/**
 * Redirects old /docs/user-guide/install/pe/edge/* URLs to /docs/edge/pe/installation/*.
 * Slugs are not 1:1 (e.g. deb-installation → ubuntu), so targets are hardcoded
 * in src/data/redirects.ts via getCatchAllEntries().
 */
import { getCatchAllEntries } from '~/data/redirects';

export function getStaticPaths() {
	return getCatchAllEntries('user-guide/install/pe/edge').map((e) => ({
		params: { slug: e.slug || undefined },
		props: { target: e.target },
	}));
}

return Astro.redirect((Astro.props as { target: string }).target, 301);
---
