---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import HeroSection from '../../../components/Trainings/HeroSection.astro';
import InfoCardsSection from '../../../components/Trainings/InfoCardsSection.astro';
import CoursesSection from '../../../components/Trainings/CoursesSection.astro';
import StatisticsSection from '../../../components/Trainings/StatisticsSection.astro';
import { courses } from '@data/trainings';
---

<BaseLayout
	forceLightTheme
	title="ThingsBoard Training Sessions | Expert IoT Workshops"
	description="Practical ThingsBoard training led by experts — 15 two-hour sessions for teams up to 8 engineers, covering visualization, admin, SCADA, and more."
	pageId="trainings"
>
	<main>
		<!-- spacer for fixed header -->
		<div class="header-spacer"></div>
		<HeroSection />
		<InfoCardsSection />
		<CoursesSection courses={courses} />
		<StatisticsSection />
	</main>
</BaseLayout>

<style>
	.header-spacer {
		padding-top: 80px;
	}
</style>